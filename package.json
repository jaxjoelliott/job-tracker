{
  "name": "aws-learning-lab",
  "version": "1.0.0",
  "description": "A 12-week structured build program learning basics of AWS serverless development documented in one Github repository.",
  "main": "dist/index.ts",
  "scripts": {
    "lint": "eslint 'src/**/*.ts' --no-error-on-unmatched-pattern",
    "test": "jest",
    "format": "prettier --write .",
    "build": "tsc",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaxjoelliott/aws-learning-lab.git"
  },
  "keywords": [
    "aws",
    "serverless",
    "learning",
    "lab",
    "typescript",
    "lambda",
    "terraform"
  ],
  "author": "Jackson Elliott",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jaxjoelliott/aws-learning-lab/issues"
  },
  "homepage": "https://github.com/jaxjoelliott/aws-learning-lab#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1034.0",
    "@aws-sdk/lib-dynamodb": "^3.1034.0",
    "dotenv": "^17.4.2"
  }
}
